@page "/"
@inject SteamAuthService SteamAuth
@inject NavigationManager Navigation

@* Page d'accueil / login — redirige vers /library si déjà connecté *@

<div class="login-container">
    <div class="login-card">
        <div class="steam-logo">
            <h1>🎮</h1>
        </div>
        
        <h1>Librairie Steam</h1>
        <p>Gérez votre bibliothèque Steam facilement</p>
        
        <button class="steam-login-btn" @onclick="LoginWithSteam">
            Se connecter avec Steam
        </button>
        
        <p class="info-text">
            Vous serez redirigé vers Steam pour vous connecter
        </p>
    </div>
</div>

@code {
    // Au chargement : traite le retour OpenID de Steam ou redirige si déjà connecté
    protected override async Task OnInitializedAsync()
    {
        var currentUrl = Navigation.Uri;
        
        // Si l'URL contient la réponse OpenID, on valide l'authentification
        if (currentUrl.Contains("openid.mode=id_res"))
        {
            Console.WriteLine("🔄 Retour de Steam détecté");
            
            var steamId = await SteamAuth.ValidateSteamLogin(currentUrl);
            
            if (!string.IsNullOrEmpty(steamId))
            {
                await SteamAuth.SaveUserSession(steamId);
                Navigation.NavigateTo("/library", forceLoad: true);
            }
            else
            {
                Console.WriteLine("❌ Échec de l'authentification");
            }
        }
        else
        {
            // Pas de retour OpenID : si déjà connecté, redirige vers la bibliothèque
            var isLoggedIn = await SteamAuth.IsLoggedIn();
            if (isLoggedIn)
            {
                Navigation.NavigateTo("/library");
            }
        }
    }
    
    // Redirige l'utilisateur vers la page de login Steam (OpenID)
    private void LoginWithSteam()
    {
        var steamLoginUrl = SteamAuth.GetSteamLoginUrl();
        Navigation.NavigateTo(steamLoginUrl, forceLoad: true);
    }
}