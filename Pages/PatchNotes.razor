@page "/patchnotes"
@inject SteamAuthService SteamAuth
@inject SteamApiService SteamApi
@inject FavoritesService Favorites
@inject NavigationManager Navigation

<div class="patchnotes-container">
    <div class="patchnotes-header">
        <a href="/library" class="back-button">
            ← Retour
        </a>
        <div class="header-content">
            <h1>📝 Patch Notes de vos jeux favoris</h1>
            <p class="subtitle">Restez informé des dernières mises à jour</p>
        </div>
    </div>
    
    @if (isLoading)
    {
        <div class="loading-state">
            <p>Chargement des patch notes...</p>
        </div>
    }
    else if (favoriteGamesWithNews.Count == 0)
    {
        <div class="empty-state">
            <p>Aucun jeu favori.</p>
            <p>Marquez des jeux en favoris dans votre bibliothèque !</p>
            <a href="/library" class="btn-library">Aller à la bibliothèque</a>
        </div>
    }
    else
    {
        <div class="games-news-container">
            @foreach (var gameNews in favoriteGamesWithNews)
            {
                <div class="game-section">
                    <div class="game-banner-header">
                        <img src="@gameNews.Game.HeaderImageUrl" alt="@gameNews.Game.Name" class="game-banner" />
                        <div class="game-overlay">
                            <h2>@gameNews.Game.Name</h2>
                            <p>@gameNews.News.Count mise(s) à jour ce mois-ci</p>
                        </div>
                    </div>
                    
                    <div class="news-container">
                        @if (gameNews.News.Count == 0)
                        {
                            <p class="no-news">Aucune mise à jour récente</p>
                        }
                        else
                        {
                            @foreach (var newsItem in gameNews.News.Take(5))
                            {
                                <div class="news-item">
                                    <div class="news-main">
                                        <h3 class="news-title">@newsItem.Title</h3>
                                        <p class="news-preview">@newsItem.ContentPreview</p>
                                        <a href="@newsItem.Url" target="_blank" class="read-more">
                                            Lire plus →
                                        </a>
                                    </div>
                                    <span class="news-date">@newsItem.DateFormatted</span>
                                </div>
                            }
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private string? steamId;
    private List<GameWithNews> favoriteGamesWithNews = new();
    private bool isLoading = true;
    
    protected override async Task OnInitializedAsync()
    {
        steamId = await SteamAuth.GetCurrentSteamId();
        
        if (string.IsNullOrEmpty(steamId))
        {
            Navigation.NavigateTo("/");
            return;
        }
        
        await LoadPatchNotes();
    }
    
    private async Task LoadPatchNotes()
    {
        isLoading = true;
        
        var allGames = await SteamApi.GetOwnedGamesAsync(steamId!);
        var favoriteIds = await Favorites.GetFavoritesAsync(steamId!);
        
        var favoriteGames = allGames.Where(g => favoriteIds.Contains(g.AppId)).ToList();
        
        favoriteGamesWithNews = new List<GameWithNews>();
        
        foreach (var game in favoriteGames)
        {
            var news = await SteamApi.GetGameNewsAsync(game.AppId);
            favoriteGamesWithNews.Add(new GameWithNews
            {
                Game = game,
                News = news
            });
        }
        
        isLoading = false;
    }
    
    private class GameWithNews
    {
        public SteamGame Game { get; set; } = new();
        public List<GameNewsItem> News { get; set; } = new();
    }
}